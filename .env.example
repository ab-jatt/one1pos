# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# ──────────────────────────────────────────────
# PostgreSQL
# ──────────────────────────────────────────────
POSTGRES_USER=nexus
POSTGRES_PASSWORD=nexus_secret
POSTGRES_DB=nexus_pos

# ──────────────────────────────────────────────
# Backend (NestJS)
# ──────────────────────────────────────────────
# Built automatically by docker-compose from the POSTGRES_* vars above.
# Override here only if you point to an external database.
DATABASE_URL=postgresql://nexus:nexus_secret@postgres:5432/nexus_pos

NODE_ENV=production
PORT=8080

# Allowed browser origin(s) for CORS (comma-separated if multiple)
CORS_ORIGIN=http://localhost:5173

# ──────────────────────────────────────────────
# Firebase Admin SDK (Backend)
# ──────────────────────────────────────────────
# Minimum required: project ID (used for token verification without a service account)
FIREBASE_PROJECT_ID=one1pos

# Optional: absolute path inside the container to a service account JSON.
# Uncomment the volume mount in docker-compose.yml when using this.
# FIREBASE_SERVICE_ACCOUNT_PATH=/app/firebase-service-account.json

# ──────────────────────────────────────────────
# Frontend (React + Vite) – BUILD-TIME variables
# ──────────────────────────────────────────────
# Must be reachable from the user's BROWSER, not from inside Docker.
VITE_API_URL=http://localhost:8080

# Firebase client-side config (already hard-coded in firebase.ts;
# set these here if you switch to import.meta.env in that file)
VITE_FIREBASE_API_KEY=AIzaSyB9mg7r-cJbt7kMdGBur4grZ9I0SI-h_Cg
VITE_FIREBASE_AUTH_DOMAIN=one1pos.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=one1pos
VITE_FIREBASE_STORAGE_BUCKET=one1pos.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=609563083362
VITE_FIREBASE_APP_ID=1:609563083362:web:de9f9115f0c1fcf1c5073b
